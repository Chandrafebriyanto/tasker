{
  "kind": "collectionType",
  "collectionName": "titles",
  "info": {
    "singularName": "title",
    "pluralName": "titles",
    "displayName": "Task"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "deadline": {
      "type": "datetime"
    },
    "priority": {
      "type": "enumeration",
      "enum": [
        "Low",
        "Medium",
        "High"
      ]
    },
    "status_task": {
      "type": "enumeration",
      "enum": [
        "Pending",
        "Completed"
      ]
    },
    "completedAt": {
      "type": "datetime"
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "tasks"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "tasks"
    }
  }
}
